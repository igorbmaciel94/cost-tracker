# GHCR image coordinates
GHCR_OWNER=igorbmaciel94
IMAGE_TAG=main

# Domain (used by docs/runbooks)
APP_DOMAIN=cost.lighthousedev.uk

# Bind ports used by Cost Tracker stack (must not conflict).
# When reverse proxy (Caddy) runs in another Docker stack, 0.0.0.0 avoids host-loopback routing issues.
# Restrict inbound access to these ports in your firewall/security group.
APP_WEB_BIND_ADDRESS=0.0.0.0
APP_WEB_BIND_PORT=18080
APP_API_BIND_ADDRESS=0.0.0.0
APP_API_BIND_PORT=18081

# Existing PostgreSQL (outside Docker compose).
# DB_USER can be an existing user from another project, as long as it has access to DB_NAME.
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=costtracker
DB_USER=costtracker
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_SSL_MODE=Disable

# Optional override for backup script (host perspective)
BACKUP_DB_HOST=127.0.0.1

# Registry login (server-side)
GHCR_USERNAME=igorbmaciel94
GHCR_TOKEN=CHANGE_ME_GHCR_READ_TOKEN

# Backup settings
BACKUP_DIR=/opt/cost-tracker/backups
BACKUP_RETENTION_DAYS=14
