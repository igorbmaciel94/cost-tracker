# This file is kept only as a reference template.
# In your current server setup, Caddy is managed by BloodWatch,
# so Cost Tracker does not run its own Caddy container.

cost.lighthousedev.uk {
  encode gzip zstd

  # compatibility route for old frontend builds that may call /api/api/*
  @api_dup path /api/api/*
  handle @api_dup {
    uri strip_prefix /api
    reverse_proxy host.docker.internal:18081
  }

  @api path /api/*
  reverse_proxy @api host.docker.internal:18081

  reverse_proxy host.docker.internal:18080
}
